# ---- Plane (self-hosted) ----
# Internal service name when running in Plane's docker network, e.g. http://api:8000
# or the external URL, e.g. https://plane.example.com
PLANE_BASE_URL=http://api:8000
PLANE_WORKSPACE_SLUG=my-workspace
PLANE_API_KEY=plane_api_xxxxxxxxxxxxxxxx
PLANE_WEBHOOK_SECRET=change-me-plane-secret
# UUID of the Plane member the bridge acts as (its writes are ignored as echoes).
PLANE_BOT_MEMBER_ID=00000000-0000-0000-0000-000000000000

# ---- GitLab (self-managed) ----
GITLAB_BASE_URL=https://gitlab.example.com
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxx
GITLAB_WEBHOOK_SECRET=change-me-gitlab-secret
# Numeric user id of the GitLab bot account (its events are ignored as echoes).
GITLAB_BOT_USER_ID=0

# ---- Bridge ----
BRIDGE_DB_URL=sqlite:////data/bridge.db
BRIDGE_PORT=8000
PROJECTS_CONFIG_PATH=/app/config/projects.yml
LOG_LEVEL=INFO

# Regex (with two groups: project-identifier, sequence-number) used to find Plane
# work-item references like PROJ-123 in branch names / MR titles / commit messages.
IDENTIFIER_REGEX=\b([A-Z][A-Z0-9]+)-(\d+)\b

# Drop duplicate webhook deliveries / our own echoes seen within this window (seconds).
DEDUPE_TTL_SECONDS=120

# Auto-creation policy (updates/closes still sync both ways once a pair is linked).
CREATE_MISSING_PLANE_ISSUE=true
CREATE_MISSING_GITLAB_ISSUE=false

# Per-field sync toggles.
SYNC_TITLE=true
SYNC_DESCRIPTION=true
SYNC_STATE=true
SYNC_LABELS=true
SYNC_ASSIGNEES=false
SYNC_DATES=true

# What to do when one side deletes an issue: close | ignore  (never hard-delete).
DELETE_BEHAVIOR=close

# Worker tuning.
WORKER_POLL_INTERVAL=1.0
MAX_ATTEMPTS=5
